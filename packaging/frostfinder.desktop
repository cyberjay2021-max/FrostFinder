[Desktop Entry]
Name=FrostFinder
GenericName=File Manager
Comment=A fast, modern file manager inspired by macOS Finder
Exec=frostfinder %u
Icon=frostfinder
Terminal=false
Type=Application
Categories=System;FileManager;Utility;
MimeType=inode/directory;
Keywords=files;folders;browser;manager;finder;
StartupNotify=true
StartupWMClass=frostfinder
X-GNOME-SingleWindow=false

[Desktop Action new-window]
Name=New Window
Exec=frostfinder

[Desktop Action open-home]
Name=Open Home Folder
Exec=frostfinder %h

Actions=new-window;open-home;
