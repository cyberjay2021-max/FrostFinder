{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrostFinder",
  "version": "1.0.1-rc3",
  "identifier": "com.frostfinder.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "FrostFinder",
        "width": 1100,
        "height": 680,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; media-src 'self' http://127.0.0.1:* asset: https://asset.localhost data: blob:; img-src 'self' http://127.0.0.1:* asset: https://asset.localhost data: blob:; frame-src http://127.0.0.1:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com http://127.0.0.1:*; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "dmg",
      "app",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A fast, modern file manager",
    "longDescription": "FrostFinder is a column-based file manager for Linux inspired by macOS Finder. Features multi-column navigation, Quick Look previews, gallery view, tag system, ISO/DMG mount support, drag-and-drop, and hardware-accelerated video via VA-API.",
    "category": "Utility",
    "copyright": "Copyright (c) 2026 FrostFinder",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "udisks2"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk-4.1 >= 2.50",
          "gtk3",
          "udisks2"
        ],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": "entitlements/macos.entitlements",
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  }
}
