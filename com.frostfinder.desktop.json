{
  "app-id": "com.frostfinder.desktop",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.node20"
  ],
  "command": "frostfinder",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=network",
    "--filesystem=host",
    "--filesystem=xdg-run/gvfs",
    "--filesystem=xdg-run/gvfsd",
    "--talk-name=org.gtk.vfs.*",
    "--talk-name=org.freedesktop.FileManager1",
    "--talk-name=org.freedesktop.UDisks2",
    "--system-talk-name=org.freedesktop.UDisks2",
    "--talk-name=org.freedesktop.Notifications",
    "--env=WEBKIT_DISABLE_COMPOSITING_MODE=1",
    "--env=XDG_DATA_DIRS=/app/share:/usr/share"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/node20/bin",
    "env": {
      "CARGO_HOME": "/run/build/frostfinder/cargo",
      "npm_config_cache": "/run/build/frostfinder/npm-cache",
      "CARGO_NET_OFFLINE": "true"
    }
  },
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/man",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "frostfinder",
      "buildsystem": "simple",
      "build-commands": [
        "npm ci --offline",
        "npm run tauri build -- --no-bundle",
        "install -Dm755 src-tauri/target/release/frostfinder /app/bin/frostfinder",
        "install -Dm644 packaging/frostfinder.desktop /app/share/applications/com.frostfinder.desktop.desktop",
        "install -Dm644 packaging/com.frostfinder.desktop.metainfo.xml /app/share/metainfo/com.frostfinder.desktop.metainfo.xml",
        "install -Dm644 src-tauri/icons/16x16.png   /app/share/icons/hicolor/16x16/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/32x32.png   /app/share/icons/hicolor/32x32/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/48x48.png   /app/share/icons/hicolor/48x48/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/64x64.png   /app/share/icons/hicolor/64x64/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/128x128.png /app/share/icons/hicolor/128x128/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/256x256.png /app/share/icons/hicolor/256x256/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/512x512.png /app/share/icons/hicolor/512x512/apps/com.frostfinder.desktop.png",
        "install -Dm644 src-tauri/icons/icon.svg    /app/share/icons/hicolor/scalable/apps/com.frostfinder.desktop.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/frostfinder/frostfinder.git",
          "tag": "v6.0.26",
          "commit": "REPLACE_WITH_COMMIT_SHA_OF_v6.0.26",
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/frostfinder/frostfinder/releases/latest",
            "tag-query": ".tag_name",
            "version-query": ".tag_name | ltrimstr(\"v\")",
            "timestamp-query": ".published_at"
          }
        },
        {
          "type": "file",
          "path": "flatpak/cargo-sources.json",
          "dest": "cargo",
          "dest-filename": "config"
        },
        {
          "type": "file",
          "path": "flatpak/node-sources.json",
          "dest": ".",
          "dest-filename": "package-lock-offline.json"
        }
      ]
    }
  ]
}
